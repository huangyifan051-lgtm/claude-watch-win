# ============================================
# Claude Code → iPhone/Apple Watch 通知配置
# 复制: cp .env.example .env 然后编辑
# ============================================

# ── 方式 A: Bark (推荐, 最简单) ──
# 1. iPhone App Store 搜索 "Bark" 安装
# 2. 打开 App, 复制显示的 URL (类似 https://api.day.app/xxxxx)
# 3. 粘贴到下面:
BARK_URL=

# ── 方式 B: ntfy.sh (备选) ──
# 1. iPhone/Android 装 ntfy App
# 2. 订阅一个主题 (topic), 比如 claude-code-你的名字
# 3. 粘贴到下面:
# NTFY_TOPIC=

# ── 通用设置 ──
# 是否发送"回答完成"通知 (1=发, 0=不发, 太频繁可以关)
NOTIFY_COMPLETE=1
